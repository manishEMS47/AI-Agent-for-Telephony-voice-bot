# The base URI for the application. This is used in the inbound.py file.
# Example: 
# BASE_URI=voice-bot.example.com
BASE_URI=

# ## LLM - Currently only OpenAI is supported
# LLM_MODEL=gpt-4o-mini
LLM_MODEL=
# The API key for OpenAI. This is used for natural language processing tasks.
OPENAI_API_KEY=

# ## TTS
# Which text-to-speech provider to use: "elevenlabs" (default) or "60db".
TTS_PROVIDER=elevenlabs

# Eleven Labs (used when TTS_PROVIDER=elevenlabs)
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_VOICE_ID=

# 60db (https://60db.ai) — used when TTS_PROVIDER=60db
# List your voices and copy a voice_id from: GET https://api.60db.ai/myvoices
SIXTYDB_API_KEY=
SIXTYDB_VOICE_ID=
# Optional 60db voice tuning (defaults shown)
SIXTYDB_SPEED=1.0
SIXTYDB_STABILITY=50
SIXTYDB_SIMILARITY=75

# ## SST
# The API key for Deepgram. This is used for speech recognition.
DEEPGRAM_API_KEY=

# ## Telephony
# The account SID and authentication token for Twilio. These are used for making API requests to Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Only for outgoing calls
# The phone number to call from.
FROM_PHONE=
# The phone number to call to.
TO_PHONE=